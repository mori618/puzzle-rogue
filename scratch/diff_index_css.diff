+}
+/* Value Increase Popup Animation */
+@keyframes float-up-fade {
+  0% {
+    opacity: 0;
+    transform: translateY(10px) scale(0.8);
+  }
+  20% {
+    opacity: 1;
+    transform: translateY(0px) scale(1.2);
+  }
+  100% {
+    opacity: 0;
+    transform: translateY(-25px) scale(1);
+  }
+}
+
+.animate-float-up-fade {
+  animation: float-up-fade 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
+}
+
+.value-popup {
+  position: absolute;
+  pointer-events: none;
+  font-weight: 900;
+  text-shadow: 0 2px 4px rgba(0,0,0,0.8), 0 0 10px currentColor;
+  z-index: 100;
+  white-space: nowrap;
+}
+
+@keyframes token-toast-slide {
+  0% {
+    transform: perspective(1000px) translateX(-100px) translate3d(-100%, 0, 0) rotateY(30deg);
+    opacity: 0;
+  }
+  15% {
+    transform: perspective(1000px) translateX(0) translate3d(0, 0, 0) rotateY(0deg);
+    opacity: 1;
+  }
+  85% {
+    transform: perspective(1000px) translateX(0) translate3d(0, 0, 0) rotateY(0deg);
+    opacity: 1;
+  }
+  100% {
+    transform: perspective(1000px) translateY(-40px) scale(0.95);
+    opacity: 0;
+  }
+}
+
+.animate-token-toast {
+  animation: token-toast-slide 3.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
+  transform-origin: left center;
+}
+/* === ショップ・トークン演出用アニメーション === */
+
+@keyframes particle-fly {
+  0% {
+    transform: translate(var(--start-x), var(--start-y)) scale(1);
+    opacity: 1;
+  }
+  15% {
+    transform: translate(calc(var(--start-x) + var(--rand-x)), calc(var(--start-y) + var(--rand-y))) scale(1.5);
+    opacity: 1;
+  }
+  100% {
+    transform: translate(var(--end-x), var(--end-y)) scale(0.5);
+    opacity: 0.2;
+  }
+}
+
+.animate-particle-fly {
+  animation: particle-fly 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
+}
+
+@keyframes purchase-success-glow {
+  0% {
+    box-shadow: 0 0 0px 0px rgba(251, 191, 36, 0);
+    transform: scale(1);
+  }
+  30% {
+    box-shadow: 0 0 30px 10px rgba(251, 191, 36, 0.6);
+    transform: scale(1.05);
+  }
+  100% {
+    box-shadow: 0 0 0px 0px rgba(251, 191, 36, 0);
+    transform: scale(1);
+  }
+}
+
+.animate-purchase-success {
+  animation: purchase-success-glow 0.6s ease-out forwards;
+}
+
+@keyframes token-level-up-flash {
+  0% {
+    filter: brightness(1) saturate(1);
+    transform: scale(1);
+  }
+  20% {
+    filter: brightness(2) saturate(2);
+    transform: scale(1.2);
+  }
+  40% {
+    filter: brightness(1.5) saturate(1.5);
+    transform: scale(1.1);
+  }
+  60% {
+    filter: brightness(1.8) saturate(1.8);
+    transform: scale(1.15);
+  }
+  100% {
+    filter: brightness(1) saturate(1);
+    transform: scale(1);
+  }
+}
+
+.animate-token-levelup {
+  animation: token-level-up-flash 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
+}
+
+@keyframes star-sparkle {
+  0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.8; }
+  50% { transform: scale(1.5) rotate(90deg); opacity: 1; }
+}
+
+.animate-star-sparkle {
+  animation: star-sparkle 0.5s ease-in-out infinite;
+}
+
+/* 高速化（ファストフォワード）モード時のアニメーション時間短縮 */
+.is-fast-forward .orb {
+  transition-duration: 0.07s !important;
+}
+
+.is-fast-forward .orb-falling {
+  transition-duration: 0.08s !important;
+}
+
+.is-fast-forward .orb-matching>* {
+  animation-duration: 0.06s !important;
+}
+
+.is-fast-forward .orb-reviving>.orb-inner {
+  animation-duration: 0.09s !important;
+}
+
+.is-fast-forward .orb-revive-ring {
+  animation-duration: 0.1s !important;
+}
+
+.is-fast-forward .rainbow-hit-pulse {
+  animation-duration: 0.06s !important;
+}
+
+.is-fast-forward .animate-combo-pop {
+  animation-duration: 0.07s !important;
+}
+
+.is-fast-forward .animate-combo-pulse {
+  animation-duration: 0.12s !important;
+}
+
+.is-fast-forward .animate-target-pulse {
+  animation-duration: 0.14s !important;
+}
+
+.is-fast-forward .animate-combo-float {
+  animation-duration: 0.2s !important;
+}
+
+.is-fast-forward .combo-bonus-add {
+  animation-duration: 0.08s !important;
+}
+
+.is-fast-forward .combo-bonus-mult {
+  animation-duration: 0.08s !important;
+}
+
+/* 倍速中マークの表示 */
+.is-fast-forward::after {
+  content: attr(data-speed-multiplier);
+  position: absolute;
+  top: 10px;
+  right: 10px;
+  background: rgba(239, 68, 68, 0.9);
+  color: white;
+  padding: 0 8px 0 24px;
+  border-radius: 6px;
+  font-size: 0.75rem;
+  font-weight: 900;
+  letter-spacing: 1px;
+  z-index: 200;
+  pointer-events: none;
+  box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
+  font-family: var(--font-display);
+  border: 1px solid rgba(255, 255, 255, 0.2);
+  animation: fast-forward-pulse 0.8s ease-in-out infinite alternate;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  height: 24px;
+  box-sizing: border-box;
+}
+
+.is-fast-forward::before {
+  content: "fast_forward";
+  font-family: 'Material Icons Round';
+  position: absolute;
+  top: 10px;
+  right: 32px;
+  font-size: 0.9rem;
+  color: white;
+  z-index: 201;
+  pointer-events: none;
+  height: 24px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  animation: fast-forward-pulse 0.8s ease-in-out infinite alternate;
+}
+
+@keyframes fast-forward-pulse {
+  0% {
+    opacity: 0.7;
+    transform: scale(0.95);
+  }
+  100% {
+    opacity: 1;
+    transform: scale(1.05);
+  }
+}
+
+/* パズル盤面セクションのセーフエリア制御 */
+.puzzle-grid-section {
+  padding-bottom: 0px;
+}
+
+@media (display-mode: standalone) {
+  .puzzle-grid-section {
+    padding-bottom: env(safe-area-inset-bottom, 16px);
+  }
+}
+
